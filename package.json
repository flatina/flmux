{
  "name": "flmux",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "extensions/*"
  ],
  "scripts": {
    "build:extension-api-runtime": "bun run --filter @flmux/extension-api build:runtime",
    "build:extensions": "bun run --filter @flmux/extension-devkit build ../../extensions/cowsay ../../extensions/counter ../../extensions/inspector ../../extensions/scratchpad",
    "build": "bun run --filter @flmux/app build",
    "dev": "bun run --filter @flmux/app dev",
    "test:direct": "cd packages/app && bun run test:direct",
    "test:smoke": "cd packages/app && bun run test:smoke",
    "test:harness-smoke": "cd packages/app && bun run test:harness-smoke",
    "typecheck": "cd packages/app && bun run typecheck",
    "validate:extensions": "bun run --filter @flmux/extension-devkit validate ../../extensions/cowsay ../../extensions/counter ../../extensions/inspector ../../extensions/scratchpad",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "check": "biome check",
    "check:fix": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12"
  }
}
