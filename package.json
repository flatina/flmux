{
  "name": "flmux",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "extensions/cowsay",
    "extensions/counter",
    "extensions/header-menu",
    "extensions/inspector",
    "extensions/scratchpad"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build:extensions": "bun scripts/dev-extensions.ts build",
    "pack:extensions": "bun scripts/pack-extensions.ts",
    "build": "bun run --filter @flmux/app build",
    "dev": "bun run --filter @flmux/app dev",
    "dev:reload": "bun scripts/dev-reload.ts",
    "test:direct": "cd packages/app && bun run test:direct",
    "test:smoke": "cd packages/app && bun run test:smoke",
    "test:harness-smoke": "cd packages/app && bun run test:harness-smoke",
    "typecheck": "cd packages/app && bun run typecheck",
    "validate:extensions": "bun scripts/dev-extensions.ts validate",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "check": "biome check",
    "check:fix": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "knip": "6.6.0",
    "ts-morph": "^28.0.0"
  },
  "dependencies": {
    "bunite-core": "^0.17.1"
  }
}
