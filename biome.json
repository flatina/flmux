{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "files": {
    "includes": ["src/**"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "rules": {
      "recommended": true,
      "correctness": { "noUnusedImports": "warn", "noUnusedVariables": "warn" },
      "style": { "noNonNullAssertion": "off", "useImportType": "warn" },
      "suspicious": { "noExplicitAny": "off" }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "always", "trailingCommas": "none" }
  }
}
