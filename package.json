{
  "name": "flmux",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "extensions/*"
  ],
  "scripts": {
    "build:extensions": "bun run --filter @flmux/extension-devkit build ../../extensions/cowsay ../../extensions/inspector ../../extensions/scratchpad",
    "build": "bun run build:extensions && bun run --filter @flmux/app build",
    "dev": "bun run build:extensions && bun run --filter @flmux/app dev",
    "test:direct": "bun run --filter @flmux/app test:direct",
    "test:smoke": "bun run --filter @flmux/app test:smoke",
    "test:harness-smoke": "bun run --filter @flmux/app test:harness-smoke",
    "typecheck": "bun run --filter @flmux/app typecheck",
    "validate:extensions": "bun run --filter @flmux/extension-devkit validate ../../extensions/cowsay ../../extensions/inspector ../../extensions/scratchpad"
  }
}
