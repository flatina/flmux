{
  "name": "@flmux/app",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ptyd": "bun build src/main/ptyd/daemonMain.ts --outfile dist/ptyd.js --target bun",
    "build:cli": "bun build src/cli.ts --outfile dist/cli.js --target bun",
    "build:renderer": "rm -rf dist/renderer && bun build src/renderer/index.html --outdir dist/renderer --minify",
    "cli": "bun src/cli.ts",
    "dev": "cd ../.. && bun run build:extensions && cd packages/app && bun run build:renderer && bun src/main.ts --dev",
    "build": "cd ../.. && bun run build:extensions && cd packages/app && bunite-build && bun run build:ptyd && bun run build:cli && bun run build:renderer",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit && bun x tsc -p src/renderer/tsconfig.json --noEmit",
    "test:direct": "bun test",
    "test:shell-model": "bun test test/shellModel.test.ts",
    "test:smoke:cdp": "bun test ./test/appSmoke.cdp.smoke.ts",
    "test:harness-smoke": "bun test ./test/harnessSmoke.smoke.ts",
    "test:browser": "playwright test"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.0.0",
    "@codemirror/lang-html": "^6.0.0",
    "@codemirror/lang-javascript": "^6.0.0",
    "@codemirror/lang-json": "^6.0.0",
    "@codemirror/lang-markdown": "^6.0.0",
    "@codemirror/lang-python": "^6.0.0",
    "@codemirror/language": "6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@codemirror/view": "^6.43.0",
    "@flatina/confkit": "^0.1.0",
    "@flmux/core": "workspace:*",
    "@flmux/extension-api": "workspace:*",
    "@simplewebauthn/server": "^13",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "bunite-core": "^0.17.1",
    "bunite-native-linux-x64": "^0.0.5",
    "bunite-native-mac-arm64": "^0.0.5",
    "bunite-native-win-x64": "^0.0.15",
    "citty": "^0.2.2",
    "codemirror": "^6.0.2",
    "dockview-core": "^6.4.0",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.6.2",
    "qrcode-terminal": "^0.12.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.12",
    "@types/qrcode-terminal": "^0.12.2",
    "bunite-dev": "^0.0.6",
    "msgpackr": "^1.11.9"
  }
}
