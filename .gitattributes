# Auto detect text files and perform LF normalization
*          text=auto

# Source — force LF (cross-platform dev on Windows + macOS)
*.ts       text eol=lf
*.js       text eol=lf
*.mjs      text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.md       text eol=lf diff=markdown
*.npmrc    text eol=lf

# Shell scripts — LF
*.sh       text eol=lf
*.bash     text eol=lf
.dev/flmux text eol=lf
.dev/flweb text eol=lf

# Windows scripts — CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Lockfile — exact bytes matter
bun.lock   text eol=lf

# Git metadata
.gitattributes text eol=lf
.gitignore     text eol=lf
.gitmodules    text eol=lf

# Binary
*.png      binary
*.ico      binary
*.exe      binary
*.dll      binary
*.node     binary
*.wasm     binary
*.lockb    binary

# Archives
*.gz       binary
*.tar      binary
*.tgz      binary
*.zip      binary
*.zst      binary

# Exclude from export
.gitattributes export-ignore
.gitignore     export-ignore
